#!/usr/bin/env bash
# send-slash — send a slash-command keystroke to (or capture) the CURRENT tmux pane.
#
# "Current pane" = the pane this script's process lives in. tmux exports
# $TMUX_PANE into every child process, so we don't have to guess.
#
# Restriction: `send` only accepts content whose first argument starts with
# "/" — this script is intentionally limited to driving slash commands.
#
# usage:
#   send-slash send /<cmd> [keys...]  # passthrough to `tmux send-keys`
#                                     #   first arg MUST start with "/"
#                                     #   later bare words = key names (Enter, Escape, ...)
#   send-slash capture                # dump visible pane contents to stdout
#   send-slash pane                   # print the resolved pane id
set -euo pipefail

if [[ -z "${TMUX:-}" ]]; then
  echo "error: not running inside tmux" >&2
  exit 1
fi

# Prefer the inherited $TMUX_PANE; fall back to asking tmux for the active pane.
pane="${TMUX_PANE:-$(tmux display-message -p '#{pane_id}')}"

usage() {
  sed -n '2,15p' "$0" >&2
  exit 2
}

cmd="${1:-}"
[[ -n "$cmd" ]] || usage
shift

case "$cmd" in
  send)
    [[ $# -gt 0 ]] || usage
    if [[ "$1" != /* ]]; then
      echo "error: send content must start with '/' (got: '$1')" >&2
      exit 3
    fi
    tmux send-keys -t "$pane" "$@"
    ;;
  capture)
    tmux capture-pane -p -t "$pane"
    ;;
  pane)
    echo "$pane"
    ;;
  *)
    usage
    ;;
esac
