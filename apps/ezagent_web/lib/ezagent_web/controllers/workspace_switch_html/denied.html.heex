<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Sign in required · ezagent</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />
    <style>
      :root {
        --font-sans: 'Geist', ui-sans-serif, system-ui, -apple-system, sans-serif;
        --font-mono: 'JetBrains Mono', ui-monospace, Menlo, monospace;
        --ink: #0a0a0a;
        --ink-dim: #525252;
        --ink-faint: #a3a3a3;
        --line: #e5e5e5;
        --accent: #ea580c;
        --bg-top: #fafafa;
        --bg-bottom: #ffffff;
        --btn-bg: #ffffff;
        --card-bg: #ffffff;
      }
      :root[data-theme="dark"] {
        --ink: #fafafa;
        --ink-dim: #a3a3a3;
        --ink-faint: #525252;
        --line: #27272a;
        --accent: #fb923c;
        --bg-top: #09090b;
        --bg-bottom: #18181b;
        --btn-bg: #18181b;
        --card-bg: #18181b;
      }
      @media (prefers-color-scheme: dark) {
        :root:not([data-theme="light"]) {
          --ink: #fafafa;
          --ink-dim: #a3a3a3;
          --ink-faint: #525252;
          --line: #27272a;
          --accent: #fb923c;
          --bg-top: #09090b;
          --bg-bottom: #18181b;
          --btn-bg: #18181b;
          --card-bg: #18181b;
        }
      }
      * { box-sizing: border-box; }
      html, body { height: 100%; margin: 0; }
      body {
        font-family: var(--font-sans);
        color: var(--ink);
        background: linear-gradient(180deg, var(--bg-top) 0%, var(--bg-bottom) 100%);
        display: grid;
        place-items: center;
        padding: 24px;
      }
      .card {
        max-width: 480px;
        width: 100%;
        background: var(--card-bg);
        border: 1px solid var(--line);
        border-radius: 12px;
        padding: 32px;
        box-shadow: 0 1px 2px rgba(0,0,0,0.04);
      }
      .badge {
        display: inline-block;
        font-family: var(--font-mono);
        font-size: 10px;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: 12px;
      }
      h1 {
        font-size: 22px;
        font-weight: 600;
        letter-spacing: -0.02em;
        margin: 0 0 16px;
        line-height: 1.3;
      }
      h1 code, p code {
        font-family: var(--font-mono);
        font-size: 0.95em;
        color: var(--accent);
        background: transparent;
        padding: 0 2px;
      }
      p {
        font-size: 14px;
        color: var(--ink-dim);
        line-height: 1.6;
        margin: 0 0 12px;
      }
      .actions { display: flex; gap: 8px; margin-top: 24px; flex-wrap: wrap; }
      .btn {
        font-family: var(--font-sans);
        font-size: 13px;
        font-weight: 500;
        padding: 9px 18px;
        border-radius: 8px;
        border: 1px solid var(--line);
        background: var(--btn-bg);
        color: var(--ink);
        text-decoration: none;
        cursor: pointer;
        transition: all 120ms ease;
      }
      .btn:hover { border-color: var(--ink); }
      .btn-primary {
        background: var(--accent);
        color: #ffffff;
        border-color: var(--accent);
      }
      .btn-primary:hover { opacity: 0.92; }
      form { margin: 0; display: inline; }
      .brand {
        position: fixed;
        top: 20px;
        left: 20px;
        font-family: var(--font-mono);
        font-size: 11px;
        letter-spacing: 0.18em;
        color: var(--ink-dim);
        text-transform: uppercase;
      }
    </style>
  </head>
  <body>
    <div class="brand">ezagent</div>
    <div class="card">
      <div class="badge">Permission required</div>
      <h1>Sign in to workspace <code>{@target_workspace}</code></h1>
      <p>
        You don't have permission to view workspace
        <code>{@target_workspace}</code> as your current identity
        (<code>{@caller_uri}</code>).
      </p>
      <p>
        To work in <code>{@target_workspace}</code>, sign in as a
        member of that workspace. This will end your current session.
      </p>
      <div class="actions">
        <form action={logout_to_login_path(@target_workspace)} method="post">
          <input
            type="hidden"
            name="_csrf_token"
            value={Plug.CSRFProtection.get_csrf_token()}
          />
          <button type="submit" class="btn btn-primary">
            Sign in to {@target_workspace}
          </button>
        </form>
        <a class="btn" href={~p"/sessions"}>Cancel</a>
      </div>
    </div>
  </body>
</html>
